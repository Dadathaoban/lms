<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Question Items</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #fcfcfc; color: #111111; font-family: 'Segoe UI', system-ui, sans-serif; }
        .sidebar { background-color: #ffffff; min-height: 100vh; border-right: 1px solid #eaeaea; }
        .sidebar .nav-link { color: #444444; font-weight: 500; border-radius: 2px; margin-bottom: 4px; padding: 10px 15px; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.05em; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { background-color: #000000; color: #ffffff; }
        .card-custom { border: 1px solid #eaeaea; border-radius: 2px; background-color: #ffffff; }
        .border-black-thick { border-top: 3px solid #000000; }
        .question-card { border-left: 4px solid #000000; border-radius: 1px; }
        .option-label { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 700; color: #666666; }
        .correct-badge { background-color: #198754; color: white; padding: 2px 8px; border-radius: 3px; font-size: 0.75rem; }
    </style>
</head>
<body>

<div class="container-fluid">
    <div class="row">
        <nav class="col-md-3 col-lg-2 d-md-block sidebar p-3">
            <div class="position-sticky">
                <div class="px-2 py-3 mb-3 border-bottom">
                    <h6 class="fw-bold text-uppercase m-0 tracking-wide">HLT TERMINAL</h6>
                    <small class="text-muted font-monospace" style="font-size: 0.7rem;">SYS-ADMIN v1.0</small>
                </div>
                <ul class="nav flex-column">
                    <li class="nav-item"><a class="nav-link" href="/admin/dashboard">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/students">Students</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/curriculum">Subjects & Lessons</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/admin/exams">Exams Module</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/result">Results Portal</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/diagnostic/exam-health">Diagnostics</a></li>
                    <li class="nav-item mt-4"><a class="nav-link text-danger border border-danger-subtle text-center" href="/logout">Secure Signout</a></li>
                </ul>
            </div>
        </nav>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 border-bottom">
                <div>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-1 small text-uppercase fw-semibold tracking-wider">
                            <li class="breadcrumb-item"><a href="/admin/exams" class="text-dark text-decoration-none">Exams Control</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Question Bank</li>
                        </ol>
                    </nav>
                    <h2 class="fw-bold text-uppercase tracking-tight">Exam Target: <span class="text-muted"><%= exam.title %></span></h2>
                </div>
                <div class="text-end">
                    <span class="badge bg-dark rounded-1 font-monospace px-3 py-2"><%= exam.duration_minutes %> MINUTES</span>
                </div>
            </div>

            <!-- Success/Error Messages -->
            <% if (typeof success !== 'undefined' && success) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <%= success %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>

            <div class="row g-4">
                <!-- ADD QUESTION FORM -->
                <div class="col-lg-5">
                    <div class="card card-custom p-4 shadow-sm border-black-thick position-sticky" style="top: 20px;">
                        <h5 class="fw-bold text-uppercase mb-3">➕ Add Question Configuration Node</h5>
                        <form action="/admin/exams/<%= exam.id %>/questions/add" method="POST" id="addQuestionForm">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <div class="mb-3">
                                <label class="form-label text-uppercase small fw-bold text-muted">Question Prompt / Statement</label>
                                <textarea name="questionText" class="form-control rounded-1" rows="3" placeholder="Type the exam question text..." required></textarea>
                            </div>
                            
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <label class="form-label option-label">Option A</label>
                                    <input type="text" name="optionA" class="form-control rounded-1" required placeholder="Enter option A">
                                </div>
                                <div class="col-6">
                                    <label class="form-label option-label">Option B</label>
                                    <input type="text" name="optionB" class="form-control rounded-1" required placeholder="Enter option B">
                                </div>
                                <div class="col-6">
                                    <label class="form-label option-label">Option C</label>
                                    <input type="text" name="optionC" class="form-control rounded-1" required placeholder="Enter option C">
                                </div>
                                <div class="col-6">
                                    <label class="form-label option-label">Option D</label>
                                    <input type="text" name="optionD" class="form-control rounded-1" required placeholder="Enter option D">
                                </div>
                            </div>

                            <!-- FIXED: Only ONE correctOption field - radio buttons -->
                            <div class="mb-4">
                                <label class="form-label text-uppercase small fw-bold text-muted d-block mb-2">
                                    🎯 Designate Correct Response Option
                                </label>
                                <div class="btn-group w-100" role="group">
                                    <input type="radio" class="btn-check" name="correctOption" id="btnradioA" value="A" autocomplete="off" required>
                                    <label class="btn btn-outline-dark fw-bold rounded-1" for="btnradioA">✅ A</label>

                                    <input type="radio" class="btn-check" name="correctOption" id="btnradioB" value="B" autocomplete="off">
                                    <label class="btn btn-outline-dark fw-bold" for="btnradioB">B</label>

                                    <input type="radio" class="btn-check" name="correctOption" id="btnradioC" value="C" autocomplete="off">
                                    <label class="btn btn-outline-dark fw-bold" for="btnradioC">C</label>

                                    <input type="radio" class="btn-check" name="correctOption" id="btnradioD" value="D" autocomplete="off">
                                    <label class="btn btn-outline-dark fw-bold rounded-1" for="btnradioD">D</label>
                                </div>
                                <small class="text-danger d-none" id="correctOptionError">⚠ Please select the correct answer!</small>
                            </div>

                            <button type="submit" class="btn btn-dark w-100 py-2 text-uppercase fw-bold tracking-wide rounded-1">
                                💾 Save Item to Question Bank
                            </button>
                        </form>
                    </div>
                </div>

                <!-- QUESTIONS LIST -->
                <div class="col-lg-7">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="fw-bold text-uppercase m-0">📝 Compiled Bank Items (<%= questions.length %>)</h5>
                        <% if (questions.length > 0) { %>
                            <span class="badge bg-success rounded-1">
                                <%= questions.filter(q => q.correct_option && ['A','B','C','D'].includes(q.correct_option)).length %> Valid
                            </span>
                        <% } %>
                    </div>

                    <% if (questions.length === 0) { %>
                        <div class="card card-custom p-5 text-center shadow-sm">
                            <p class="text-muted font-monospace mb-0 small">
                                📭 The question tracking cluster for this exam node is currently unpopulated. 
                                Compile entries using the configuration vector input form.
                            </p>
                        </div>
                    <% } else { %>
                        <div class="d-flex flex-column gap-3">
                            <% questions.forEach(function(q, index) { %>
                                <div class="card card-custom p-4 shadow-sm question-card">
                                    <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3">
                                        <div>
                                            <span class="fw-bold font-monospace text-uppercase" style="font-size: 0.85rem;">
                                                Item #<%= index + 1 %>
                                            </span>
                                            <span class="correct-badge ms-2">
                                                ✅ Correct: <%= q.correct_option || 'NOT SET ⚠' %>
                                            </span>
                                        </div>
                                        <div class="d-flex gap-1">
                                            <button class="btn btn-xs btn-outline-dark rounded-1 font-monospace" 
                                                    style="font-size:0.75rem; padding: 2px 6px;" 
                                                    data-bs-toggle="modal" 
                                                    data-bs-target="#editQuestionModal<%= q.id %>">
                                                ✏ Edit
                                            </button>
                                            <form action="/admin/exams/<%= exam.id %>/questions/delete/<%= q.id %>" 
                                                  method="POST" 
                                                  onsubmit="return confirm('⚠ Permanently delete Question #<%= index + 1 %>?');" 
                                                  style="display:inline;">
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                <button type="submit" class="btn btn-xs btn-outline-danger rounded-1 font-monospace" 
                                                        style="font-size:0.75rem; padding: 2px 6px;">
                                                    🗑 Purge
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                    <p class="fw-semibold text-dark mb-3" style="font-size: 1.05rem;">
                                        <%= q.question_text %>
                                    </p>
                                    
                                    <div class="row g-2 font-monospace small">
                                        <div class="col-md-6 text-truncate <%= q.correct_option === 'A' ? 'fw-bold text-success' : 'text-muted' %>">
                                            <span class="badge bg-secondary me-1">A</span> <%= q.option_a %>
                                            <%= q.correct_option === 'A' ? ' ✅' : '' %>
                                        </div>
                                        <div class="col-md-6 text-truncate <%= q.correct_option === 'B' ? 'fw-bold text-success' : 'text-muted' %>">
                                            <span class="badge bg-secondary me-1">B</span> <%= q.option_b %>
                                            <%= q.correct_option === 'B' ? ' ✅' : '' %>
                                        </div>
                                        <div class="col-md-6 text-truncate <%= q.correct_option === 'C' ? 'fw-bold text-success' : 'text-muted' %>">
                                            <span class="badge bg-secondary me-1">C</span> <%= q.option_c %>
                                            <%= q.correct_option === 'C' ? ' ✅' : '' %>
                                        </div>
                                        <div class="col-md-6 text-truncate <%= q.correct_option === 'D' ? 'fw-bold text-success' : 'text-muted' %>">
                                            <span class="badge bg-secondary me-1">D</span> <%= q.option_d %>
                                            <%= q.correct_option === 'D' ? ' ✅' : '' %>
                                        </div>
                                    </div>
                                </div>

                                <!-- EDIT QUESTION MODAL -->
                                <div class="modal fade" id="editQuestionModal<%= q.id %>" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog modal-lg">
                                        <div class="modal-content rounded-1 border-0 shadow-lg">
                                            <div class="modal-header bg-dark text-white rounded-0">
                                                <h5 class="modal-title text-uppercase fw-bold small">
                                                    ✏ Edit Question #<%= index + 1 %> 
                                                    <span class="correct-badge ms-2">Current Answer: <%= q.correct_option %></span>
                                                </h5>
                                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                            </div>
                                            <form action="/admin/exams/<%= exam.id %>/questions/edit/<%= q.id %>" method="POST">
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                <div class="modal-body text-start">
                                                    <div class="mb-3">
                                                        <label class="form-label text-uppercase small fw-bold text-muted">Question Text</label>
                                                        <textarea name="questionText" class="form-control rounded-1" rows="3" required><%= q.question_text %></textarea>
                                                    </div>
                                                    
                                                    <div class="row g-2 mb-3">
                                                        <div class="col-6">
                                                            <label class="form-label option-label small fw-bold">Option A</label>
                                                            <input type="text" name="optionA" class="form-control rounded-1" value="<%= q.option_a %>" required>
                                                        </div>
                                                        <div class="col-6">
                                                            <label class="form-label option-label small fw-bold">Option B</label>
                                                            <input type="text" name="optionB" class="form-control rounded-1" value="<%= q.option_b %>" required>
                                                        </div>
                                                        <div class="col-6">
                                                            <label class="form-label option-label small fw-bold">Option C</label>
                                                            <input type="text" name="optionC" class="form-control rounded-1" value="<%= q.option_c %>" required>
                                                        </div>
                                                        <div class="col-6">
                                                            <label class="form-label option-label small fw-bold">Option D</label>
                                                            <input type="text" name="optionD" class="form-control rounded-1" value="<%= q.option_d %>" required>
                                                        </div>
                                                    </div>

                                                    <div class="mb-2">
                                                        <label class="form-label text-uppercase small fw-bold text-muted d-block mb-2">
                                                            🎯 Select Correct Answer
                                                        </label>
                                                        <div class="btn-group w-100" role="group">
                                                            <input type="radio" class="btn-check" name="correctOption" 
                                                                   id="editradioA<%= q.id %>" value="A" 
                                                                   <%= q.correct_option === 'A' ? 'checked' : '' %> required>
                                                            <label class="btn btn-outline-dark fw-bold rounded-1" for="editradioA<%= q.id %>">✅ A</label>

                                                            <input type="radio" class="btn-check" name="correctOption" 
                                                                   id="editradioB<%= q.id %>" value="B" 
                                                                   <%= q.correct_option === 'B' ? 'checked' : '' %>>
                                                            <label class="btn btn-outline-dark fw-bold" for="editradioB<%= q.id %>">B</label>

                                                            <input type="radio" class="btn-check" name="correctOption" 
                                                                   id="editradioC<%= q.id %>" value="C" 
                                                                   <%= q.correct_option === 'C' ? 'checked' : '' %>>
                                                            <label class="btn btn-outline-dark fw-bold" for="editradioC<%= q.id %>">C</label>

                                                            <input type="radio" class="btn-check" name="correctOption" 
                                                                   id="editradioD<%= q.id %>" value="D" 
                                                                   <%= q.correct_option === 'D' ? 'checked' : '' %>>
                                                            <label class="btn btn-outline-dark fw-bold rounded-1" for="editradioD<%= q.id %>">D</label>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="modal-footer bg-light rounded-0">
                                                    <button type="button" class="btn btn-secondary btn-sm rounded-1" data-bs-dismiss="modal">Cancel</button>
                                                    <button type="submit" class="btn btn-dark btn-sm rounded-1 text-uppercase fw-bold">
                                                        💾 Save Changes
                                                    </button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
            </div>
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Validate that a correct option is selected before form submission
    document.getElementById('addQuestionForm').addEventListener('submit', function(e) {
        const selectedOption = document.querySelector('input[name="correctOption"]:checked');
        const errorMsg = document.getElementById('correctOptionError');
        
        if (!selectedOption) {
            e.preventDefault();
            errorMsg.classList.remove('d-none');
            return false;
        } else {
            errorMsg.classList.add('d-none');
            console.log('✅ Submitting with correct option:', selectedOption.value);
        }
    });
</script>
</body>
</html>