<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Exam Health Diagnostic</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #fcfcfc; color: #111111; font-family: 'Segoe UI', system-ui, sans-serif; }
        .sidebar { background-color: #ffffff; min-height: 100vh; border-right: 1px solid #eaeaea; }
        .sidebar .nav-link { color: #444444; font-weight: 500; border-radius: 2px; margin-bottom: 4px; padding: 10px 15px; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.05em; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { background-color: #000000; color: #ffffff; }
        .card-custom { border: 1px solid #eaeaea; border-radius: 2px; background-color: #ffffff; }
        .border-black-thick { border-top: 3px solid #000000; }
        .row-broken { background-color: #fff3cd; }
        .row-valid { background-color: #d4edda; }
        .stat-card { border-left: 4px solid; border-radius: 2px; }
        .stat-broken { border-color: #dc3545; }
        .stat-valid { border-color: #198754; }
        .stat-total { border-color: #000000; }
        .fix-form { display: inline-flex; align-items: center; gap: 6px; }
        .fix-form select { width: 70px; font-size: 0.85rem; }
        .fix-form button { font-size: 0.8rem; padding: 2px 10px; }
    </style>
</head>
<body>

<div class="container-fluid">
    <div class="row">
        <nav class="col-md-3 col-lg-2 d-md-block sidebar p-3">
            <div class="position-sticky">
                <div class="px-2 py-3 mb-3 border-bottom">
                    <h6 class="fw-bold text-uppercase m-0 tracking-wide">HLT TERMINAL</h6>
                    <small class="text-muted font-monospace" style="font-size: 0.7rem;">SYS-ADMIN v1.0</small>
                </div>
                <ul class="nav flex-column">
                    <li class="nav-item"><a class="nav-link" href="/admin/dashboard">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/students">Students</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/curriculum">Subjects & Lessons</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/exams">Exams Module</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/result">Results Portal</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/admin/diagnostic/exam-health">Diagnostics</a></li>
                    <li class="nav-item mt-4"><a class="nav-link text-danger border border-danger-subtle text-center" href="/logout">Secure Signout</a></li>
                </ul>
            </div>
        </nav>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 border-bottom">
                <div>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-1 small text-uppercase fw-semibold tracking-wider">
                            <li class="breadcrumb-item"><a href="/admin/dashboard" class="text-dark text-decoration-none">Admin</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Exam Health Diagnostic</li>
                        </ol>
                    </nav>
                    <h2 class="fw-bold text-uppercase tracking-tight">Exam Health Diagnostic</h2>
                    <small class="text-muted">Audit and repair question correct_option values across all exams</small>
                </div>
            </div>

            <% if (success) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <%= success %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>
            <% if (error) { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <%= error %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>

            <!-- Summary Stats -->
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="card card-custom p-3 shadow-sm stat-card stat-total">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <small class="text-muted text-uppercase fw-bold" style="font-size:0.75rem;">Total Questions</small>
                                <h3 class="mb-0 fw-bold"><%= totalQuestions %></h3>
                            </div>
                            <div class="font-monospace text-muted" style="font-size:2rem;">📋</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card card-custom p-3 shadow-sm stat-card stat-valid">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <small class="text-muted text-uppercase fw-bold" style="font-size:0.75rem;">Valid (A/B/C/D)</small>
                                <h3 class="mb-0 fw-bold text-success"><%= totalValid %></h3>
                            </div>
                            <div class="font-monospace text-muted" style="font-size:2rem;">✅</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card card-custom p-3 shadow-sm stat-card stat-broken">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <small class="text-muted text-uppercase fw-bold" style="font-size:0.75rem;">Broken (NULL/Invalid)</small>
                                <h3 class="mb-0 fw-bold text-danger"><%= totalBroken %></h3>
                            </div>
                            <div class="font-monospace text-muted" style="font-size:2rem;">⚠️</div>
                        </div>
                    </div>
                </div>
            </div>

            <% if (totalBroken > 0) { %>
                <div class="alert alert-warning border-0 shadow-sm mb-4">
                    <strong>⚠ Repair Mode Active:</strong> You have <span class="fw-bold text-danger"><%= totalBroken %></span> question(s) with NULL or invalid correct_option values. 
                    These questions will <strong>never</strong> mark any student answer as correct. Use the fix forms below to correct them.
                </div>
            <% } else if (totalQuestions > 0) { %>
                <div class="alert alert-success border-0 shadow-sm mb-4">
                    <strong>✅ All Clear:</strong> Every question across all exams has a valid correct_option value (A, B, C, or D).
                </div>
            <% } %>

            <!-- Per-Exam Breakdown -->
            <% if (exams.length === 0) { %>
                <div class="card card-custom p-5 text-center shadow-sm">
                    <p class="text-muted font-monospace mb-0 small">No exams found in the system.</p>
                </div>
            <% } %>

            <% exams.forEach(function(exam) { %>
                <div class="card card-custom shadow-sm mb-4">
                    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-0 fw-bold text-uppercase"><%= exam.title %></h6>
                            <small class="text-white-50"><%= exam.subject_name %> — <%= exam.class_name %></small>
                        </div>
                        <div class="d-flex gap-2 align-items-center">
                            <span class="badge bg-light text-dark rounded-1"><%= exam.totalQuestions %> Qs</span>
                            <% if (exam.brokenCount > 0) { %>
                                <span class="badge bg-danger rounded-1"><%= exam.brokenCount %> Broken</span>
                            <% } else { %>
                                <span class="badge bg-success rounded-1">All Valid</span>
                            <% } %>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <% if (exam.questions.length === 0) { %>
                            <p class="text-muted text-center py-3 mb-0 font-monospace small">No questions in this exam.</p>
                        <% } else { %>
                            <div class="table-responsive">
                                <table class="table table-sm table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="width:40px;">#</th>
                                            <th style="width:50px;">ID</th>
                                            <th>Question</th>
                                            <th style="width:50px;">A</th>
                                            <th style="width:50px;">B</th>
                                            <th style="width:50px;">C</th>
                                            <th style="width:50px;">D</th>
                                            <th style="width:90px;">Correct</th>
                                            <th style="width:150px;">Repair</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% exam.questions.forEach(function(q, idx) { 
                                            const isValid = q.correct_option && ['A','B','C','D'].includes(q.correct_option);
                                        %>
                                            <tr class="<%= isValid ? 'row-valid' : 'row-broken' %>">
                                                <td class="font-monospace"><%= idx + 1 %></td>
                                                <td class="font-monospace"><%= q.id %></td>
                                                <td><small><%= q.question_text ? q.question_text.substring(0, 80) : '(empty)' %><%= q.question_text && q.question_text.length > 80 ? '...' : '' %></small></td>
                                                <td class="text-center <%= q.correct_option === 'A' ? 'fw-bold text-success' : '' %>">
                                                    <small><%= q.correct_option === 'A' ? '✅' : '·' %></small>
                                                </td>
                                                <td class="text-center <%= q.correct_option === 'B' ? 'fw-bold text-success' : '' %>">
                                                    <small><%= q.correct_option === 'B' ? '✅' : '·' %></small>
                                                </td>
                                                <td class="text-center <%= q.correct_option === 'C' ? 'fw-bold text-success' : '' %>">
                                                    <small><%= q.correct_option === 'C' ? '✅' : '·' %></small>
                                                </td>
                                                <td class="text-center <%= q.correct_option === 'D' ? 'fw-bold text-success' : '' %>">
                                                    <small><%= q.correct_option === 'D' ? '✅' : '·' %></small>
                                                </td>
                                                <td class="text-center">
                                                    <% if (isValid) { %>
                                                        <span class="badge bg-success"><%= q.correct_option %></span>
                                                    <% } else { %>
                                                        <span class="badge bg-danger"><%= q.correct_option || 'NULL' %></span>
                                                    <% } %>
                                                </td>
                                                <td>
                                                    <form action="/admin/diagnostic/fix-correct-option" method="POST" class="fix-form">
                                                        <input type="hidden" name="questionId" value="<%= q.id %>">
                                                        <input type="hidden" name="examId" value="<%= exam.id %>">
                                                        <select name="newCorrectOption" class="form-select form-select-sm rounded-1">
                                                            <option value="A" <%= q.correct_option === 'A' ? 'selected' : '' %>>A</option>
                                                            <option value="B" <%= q.correct_option === 'B' ? 'selected' : '' %>>B</option>
                                                            <option value="C" <%= q.correct_option === 'C' ? 'selected' : '' %>>C</option>
                                                            <option value="D" <%= q.correct_option === 'D' ? 'selected' : '' %>>D</option>
                                                        </select>
                                                        <button type="submit" class="btn btn-dark btn-sm rounded-1 fw-bold">Fix</button>
                                                    </form>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
