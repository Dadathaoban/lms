<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Curriculum Control Console</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #fcfcfc; color: #111111; font-family: 'Segoe UI', system-ui, sans-serif; }
        .sidebar { background-color: #ffffff; min-height: 100vh; border-right: 1px solid #eaeaea; }
        .sidebar .nav-link { color: #444444; font-weight: 500; border-radius: 2px; margin-bottom: 4px; padding: 10px 15px; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.05em; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { background-color: #000000; color: #ffffff; }
        .card-custom { border: 1px solid #eaeaea; border-radius: 2px; background-color: #ffffff; }
        .table-custom { border: 1px solid #eaeaea; background-color: #ffffff; }
        .table-custom th { background-color: #000000; color: #ffffff; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05em; }
        .border-black-thick { border-top: 3px solid #000000; }
    </style>
</head>
<body>

<div class="container-fluid">
    <div class="row">
        <nav class="col-md-3 col-lg-2 d-md-block sidebar p-3">
            <div class="position-sticky">
                <div class="px-2 py-3 mb-3 border-bottom">
                    <h6 class="fw-bold text-uppercase m-0 tracking-wide">HLT TERMINAL</h6>
                    <small class="text-muted font-monospace" style="font-size: 0.7rem;">SYS-ADMIN v1.0</small>
                </div>
                <ul class="nav flex-column">
                    <li class="nav-item"><a class="nav-link" href="/admin/dashboard">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/students">Students</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/admin/curriculum">Subjects & Lessons</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/exams">Exams Module</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/result">Results Portal</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/diagnostic/exam-health">Diagnostics</a></li>
                    <li class="nav-item mt-4"><a class="nav-link text-danger border border-danger-subtle text-center" href="/logout">Secure Signout</a></li>
                </ul>
            </div>
        </nav>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 border-bottom">
                <h2 class="fw-bold text-uppercase tracking-tight">Curriculum & Courseware Architect</h2>
                <div class="text-muted font-monospace small">Operator: <%= user.fullName %></div>
            </div>

            <% if (success) { %>
                <div class="alert alert-success border-0 rounded-1 shadow-sm py-3 font-monospace mb-4" style="background-color: #000000; color: #ffffff;">
                    ✓ <%= success %>
                </div>
            <% } %>

            <div class="row g-4">
                <div class="col-lg-5">
                    <div class="card card-custom p-4 shadow-sm border-black-thick">
                        <h5 class="fw-bold text-uppercase mb-3">Publish New Lesson Plan</h5>
                        
                        <form action="/admin/curriculum/lesson/create" method="POST" enctype="multipart/form-data">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <div class="mb-3">
                                <label class="form-label text-uppercase small fw-bold text-muted">Lesson Title</label>
                                <input type="text" name="title" class="form-control rounded-1" placeholder="e.g., Solid State Mechanical Properties" required>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label text-uppercase small fw-bold text-muted">Subject Track</label>
                                    <select name="subjectId" class="form-select rounded-1" required>
                                        <option value="" disabled selected>Choose Subject...</option>
                                        <% subjects.forEach(function(s) { %>
                                            <option value="<%= s.id %>"><%= s.subject_name %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-uppercase small fw-bold text-muted">Class Target</label>
                                    <select name="classId" class="form-select rounded-1" required>
                                        <option value="" disabled selected>Choose Level...</option>
                                        <% classes.forEach(function(c) { %>
                                            <option value="<%= c.id %>"><%= c.class_name %></option>
                                        <% }) %>
                                    </select>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-uppercase small fw-bold text-muted">Video Tutorial URL (Optional)</label>
                                <input type="url" name="videoUrl" class="form-control rounded-1 font-monospace" placeholder="e.g., https://youtube.com/embed/...">
                            </div>
                            <div class="mb-4">
                                <label class="form-label text-uppercase small fw-bold text-muted">Lecture Document (PDF, DOCX, PPTX)</label>
                                <input type="file" name="documentFile" class="form-control rounded-1" accept=".pdf,.docx,.pptx,.doc,.ppt" required>
                                <div class="form-text small text-muted">Maximum payload dimension limits capped at 15MB per transmission pipeline.</div>
                            </div>
                            <button type="submit" class="btn btn-dark w-100 py-2 text-uppercase fw-bold tracking-wide rounded-1">Commit Lesson Blueprint</button>
                        </form>
                    </div>
                </div>

                <div class="col-lg-7">
                    <div class="card card-custom p-4 shadow-sm">
                        <h5 class="fw-bold text-uppercase mb-3">Active Lesson Catalog Index</h5>
                        <div class="table-responsive">
                            <table class="table table-custom align-middle text-center mb-0">
                                <thead>
                                    <tr>
                                        <th class="py-3">Class Level</th>
                                        <th class="py-3">Subject Track</th>
                                        <th class="py-3">Lesson Topic Blueprint</th>
                                        <th class="py-3">Resource File</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (lessons.length === 0) { %>
                                        <tr>
                                            <td colspan="4" class="text-muted font-monospace py-4 small">No interactive lessons published to the system node database. Use the generation interface configuration matrix to build your tracks.</td>
                                        </tr>
                                    <% } else { %>
                                        <% lessons.forEach(function(lesson) { %>
                                            <tr>
    <td class="font-monospace fw-bold py-3"><%= lesson.class_name %></td>
    <td><span class="badge bg-dark px-2 py-1"><%= lesson.subject_name %></span></td>
    <td class="text-start ps-2 fw-semibold"><%= lesson.title %></td>
    <td class="font-monospace text-muted small">
        <%= lesson.video_url ? '📹 Video' : '' %>
        <%= lesson.document_url ? '📄 PDF' : '' %>
        <%= (!lesson.video_url && !lesson.document_url) ? 'None' : '' %>
    </td>
    <td>
        <div class="d-flex justify-content-center gap-2">
            <button class="btn btn-sm btn-outline-dark rounded-1 px-2 py-1" data-bs-toggle="modal" data-bs-target="#editLessonModal<%= lesson.id %>">
                ✏ Edit
            </button>
            
            <form action="/admin/curriculum/lesson/delete/<%= lesson.id %>" method="POST" onsubmit="return confirm('Purge this lesson permanently from system architecture?');" style="display:inline;">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn btn-sm btn-outline-danger rounded-1 px-2 py-1">
                    🗑 Delete
                </button>
            </form>
        </div>
    </td>
</tr>

<div class="modal fade" id="editLessonModal<%= lesson.id %>" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content rounded-1 border-0 shadow-lg">
            <div class="modal-header bg-dark text-white rounded-0">
                <h5 class="modal-title text-uppercase fw-bold small">Edit Lesson Element Node</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/admin/curriculum/lesson/edit/<%= lesson.id %>" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label text-uppercase small fw-bold text-muted">Lesson Title</label>
                        <input type="text" name="title" class="form-control rounded-1" value="<%= lesson.title %>" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-uppercase small fw-bold text-muted">Subject Track</label>
                        <select name="subjectId" class="form-select rounded-1" required>
                            <% subjects.forEach(function(s) { %>
                                <option value="<%= s.id %>" <%= lesson.subject_name === s.subject_name ? 'selected' : '' %>><%= s.subject_name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-uppercase small fw-bold text-muted">Class Target</label>
                        <select name="classId" class="form-select rounded-1" required>
                            <% classes.forEach(function(c) { %>
                                <option value="<%= c.id %>" <%= lesson.class_name === c.class_name ? 'selected' : '' %>><%= c.class_name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-uppercase small fw-bold text-muted">Video Streaming URL</label>
                        <input type="url" name="videoUrl" class="form-control rounded-1 font-monospace" value="<%= lesson.video_url %>">
                    </div>
                </div>
                <div class="modal-footer bg-light rounded-0">
                    <button type="button" class="btn btn-secondary btn-sm rounded-1" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-dark btn-sm rounded-1 text-uppercase fw-bold">Commit Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>
                                            <tr>
                                                <td class="font-monospace fw-bold py-3"><%= lesson.class_name %></td>
                                                <td><span class="badge bg-dark px-2 py-1"><%= lesson.subject_name %></span></td>
                                                <td class="text-start ps-2 fw-semibold"><%= lesson.title %></td>
                                                <td class="font-monospace small">
                                                    <% if (lesson.document_url) { %>
                                                        <a href="<%= lesson.document_url %>" target="_blank" class="btn btn-sm btn-outline-dark font-monospace py-1 px-2 rounded-1">
                                                            ⬇ View Doc
                                                        </a>
                                                    <% } else { %>
                                                        <span class="text-muted small">No File</span>
                                                    <% } %>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
