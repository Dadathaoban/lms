<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Details - <%= student.full_name %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container py-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/admin/students">Students</a></li>
                <li class="breadcrumb-item active"><%= student.full_name %></li>
            </ol>
        </nav>

        <div class="row">
            <div class="col-md-4">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0">Student Information</h5>
                    </div>
                    <div class="card-body">
                        <p><strong>ID:</strong> <span class="font-monospace"><%= student.username %></span></p>
                        <p><strong>Name:</strong> <%= student.full_name %></p>
                        <p><strong>Class:</strong> <%= student.class_name || 'Not Assigned' %></p>
                        <p><strong>Parent Contact:</strong> <%= student.parent_phone || 'N/A' %></p>
                        <p>
                            <strong>Status:</strong>
                            <% if (student.account_status === 'active') { %>
                                <span class="badge bg-success">Active</span>
                            <% } else if (student.account_status === 'frozen') { %>
                                <span class="badge bg-warning text-dark">Frozen</span>
                            <% } else { %>
                                <span class="badge bg-danger">Deleted</span>
                            <% } %>
                        </p>
                        <p><strong>Average Score:</strong> <%= parseFloat(student.avg_score).toFixed(1) %>%</p>
                        <p><strong>Total Attempts:</strong> <%= student.total_attempts %></p>
                    </div>
                </div>
            </div>
            
            <div class="col-md-8">
                <div class="card shadow-sm">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0">Recent Exam Attempts</h5>
                    </div>
                    <div class="card-body">
                        <% if (attempts.length === 0) { %>
                            <p class="text-muted">No exam attempts yet.</p>
                        <% } else { %>
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Exam</th>
                                        <th>Score</th>
                                        <th>Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% attempts.forEach(function(attempt) { %>
                                        <tr>
                                            <td><%= attempt.exam_title %></td>
                                            <td><%= attempt.score_percentage %>%</td>
                                            <td><%= new Date(attempt.created_at).toLocaleDateString() %></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
        
        <a href="/admin/students" class="btn btn-dark mt-3">← Back to Students</a>
    </div>
</body>
</html>