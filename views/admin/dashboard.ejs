<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Command Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #fcfcfc; color: #111111; font-family: 'Segoe UI', system-ui, sans-serif; }
        .sidebar { background-color: #ffffff; min-height: 100vh; border-right: 1px solid #eaeaea; }
        .sidebar .nav-link { color: #444444; font-weight: 500; border-radius: 2px; margin-bottom: 4px; padding: 10px 15px; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.05em; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { background-color: #000000; color: #ffffff; }
        .card-custom { border: 1px solid #eaeaea; border-radius: 2px; background-color: #ffffff; }
        .border-black-thick { border-top: 3px solid #000000; }
    </style>
</head>
<body>

<div class="container-fluid">
    <div class="row">
        <nav class="col-md-3 col-lg-2 d-md-block sidebar p-3">
            <div class="position-sticky">
                <div class="px-2 py-3 mb-3 border-bottom">
                    <h6 class="fw-bold text-uppercase m-0 tracking-wide">HLT TERMINAL</h6>
                    <small class="text-muted font-monospace" style="font-size: 0.7rem;">SYS-ADMIN v1.0</small>
                </div>
                <ul class="nav flex-column">
                    <li class="nav-item"><a class="nav-link active" href="/admin/dashboard">Dashboard</a></li>
                   <li class="nav-item"><a class="nav-link" href="/admin/students">Students</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Teachers</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/curriculum">Subjects</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/exams">Exams Module</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/result">Results Portal</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/diagnostic/exam-health">Diagnostics</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">System Metrics</a></li>
                    <li class="nav-item mt-4"><a class="nav-link text-danger border border-danger-subtle text-center" href="/logout">Secure Signout</a></li>
                </ul>
            </div>
        </nav>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 border-bottom">
                <h2 class="fw-bold text-uppercase tracking-tight">System Administration Overview</h2>
                <div class="text-muted font-monospace small">Operator: <%= user.fullName %></div>
            </div>

            <div class="card card-custom p-4 mb-4 border-black-thick shadow-sm">
                <h5 class="fw-bold text-uppercase mb-2">System Initialized Successfully</h5>
                <p class="text-muted mb-0 font-monospace small">Environment verified. Secure connection established with Neon PostgreSQL instance. Use the configuration navigation block to orchestrate assignments, review performance outputs, and register users.</p>
            </div>

            <div class="row g-3">
                <div class="col-md-4">
                    <div class="card card-custom p-3 shadow-sm">
                        <div class="text-muted text-uppercase small font-monospace fw-bold">Active Connections</div>
                        <h3 class="fw-bold mt-2 mb-0">Operational</h3>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card card-custom p-3 shadow-sm">
                        <div class="text-muted text-uppercase small font-monospace fw-bold">Registered Scholars</div>
                        <h3 class="fw-bold mt-2 mb-0">Pending sync...</h3>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card card-custom p-3 shadow-sm">
                        <div class="text-muted text-uppercase small font-monospace fw-bold">Curriculum Units</div>
                        <h3 class="fw-bold mt-2 mb-0">8 Tracks</h3>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>