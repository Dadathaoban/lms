<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body { background-color: #fcfcfc; color: #111111; font-family: 'Segoe UI', system-ui, sans-serif; }
        .sidebar { background-color: #ffffff; min-height: 100vh; border-right: 1px solid #eaeaea; }
        .sidebar .nav-link { color: #444444; font-weight: 500; border-radius: 2px; margin-bottom: 4px; padding: 10px 15px; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.05em; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { background-color: #000000; color: #ffffff; }
        .table-custom { background-color: #ffffff; border-radius: 4px; overflow: hidden; }
        .table-custom thead { background-color: #000000; color: #ffffff; }
        .status-badge { font-size: 0.75rem; padding: 4px 10px; }
        .action-btn { font-size: 0.75rem; padding: 3px 8px; }
    </style>
</head>
<body>

<div class="container-fluid">
    <div class="row">
        <nav class="col-md-3 col-lg-2 d-md-block sidebar p-3">
            <div class="position-sticky">
                <div class="px-2 py-3 mb-3 border-bottom">
                    <h6 class="fw-bold text-uppercase m-0 tracking-wide">HLT TERMINAL</h6>
                    <small class="text-muted font-monospace" style="font-size: 0.7rem;">SYS-ADMIN v1.0</small>
                </div>
                <ul class="nav flex-column">
                    <li class="nav-item"><a class="nav-link" href="/admin/dashboard">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/admin/students">Students</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/curriculum">Subjects & Lessons</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/exams">Exams Module</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/result">Results Portal</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/diagnostic/exam-health">Diagnostics</a></li>
                    <li class="nav-item mt-4"><a class="nav-link text-danger border border-danger-subtle text-center" href="/logout">Secure Signout</a></li>
                </ul>
            </div>
        </nav>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 border-bottom">
                <div>
                    <h2 class="fw-bold text-uppercase tracking-tight">Student Management Console</h2>
                    <p class="text-muted small mb-0">Register, monitor, and manage student accounts</p>
                </div>
                <button class="btn btn-dark rounded-1 text-uppercase fw-bold" data-bs-toggle="modal" data-bs-target="#addStudentModal">
                    <i class="bi bi-person-plus"></i> Register New Student
                </button>
            </div>

            <!-- Success/Error Messages -->
            <% if (typeof success !== 'undefined' && success) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle"></i> <%= success %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>

            <!-- Students Table -->
            <div class="table-responsive table-custom shadow-sm">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Student ID</th>
                            <th>Full Name</th>
                            <th>Class</th>
                            <th>Parent Contact</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (students.length === 0) { %>
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    No students registered yet
                                </td>
                            </tr>
                        <% } else { %>
                            <% students.forEach(function(student) { %>
                                <tr>
                                    <td class="font-monospace fw-bold"><%= student.username %></td>
                                    <td><%= student.full_name %></td>
                                    <td><%= student.class_name || 'Not Assigned' %></td>
                                    <td><%= student.parent_phone || 'N/A' %></td>
                                    <td>
                                        <% if (student.account_status === 'frozen') { %>
                                            <span class="badge bg-warning text-dark status-badge">
                                                <i class="bi bi-snow"></i> FROZEN
                                            </span>
                                        <% } else if (student.account_status === 'deleted') { %>
                                            <span class="badge bg-danger status-badge">
                                                <i class="bi bi-x-circle"></i> DELETED
                                            </span>
                                        <% } else { %>
                                            <span class="badge bg-success status-badge">
                                                <i class="bi bi-check-circle"></i> ACTIVE
                                            </span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <div class="btn-group">
                                            <!-- View Details -->
                                            <a href="/admin/students/<%= student.id %>/details" 
                                               class="btn btn-sm btn-outline-dark action-btn" 
                                               title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            
                                            <!-- Freeze/Unfreeze -->
                                            <% if (student.account_status !== 'deleted') { %>
                                                <form action="/admin/students/<%= student.id %>/toggle-freeze" 
                                                      method="POST" 
                                                      style="display:inline;"
                                                      onsubmit="return confirm('<%= student.account_status === "frozen" ? "Unfreeze" : "Freeze" %> account for <%= student.full_name %>?');">
                                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                    <button type="submit" 
                                                            class="btn btn-sm btn-outline-warning action-btn"
                                                            title="<%= student.account_status === 'frozen' ? 'Unfreeze Account' : 'Freeze Account' %>">
                                                        <% if (student.account_status === 'frozen') { %>
                                                            <i class="bi bi-sun"></i>
                                                        <% } else { %>
                                                            <i class="bi bi-snow"></i>
                                                        <% } %>
                                                    </button>
                                                </form>
                                                
                                                <!-- Soft Delete -->
                                                <form action="/admin/students/<%= student.id %>/delete" 
                                                      method="POST" 
                                                      style="display:inline;"
                                                      onsubmit="return confirm('Are you sure you want to delete the account for <%= student.full_name %>? This action can be reversed by an admin.');">
                                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                    <button type="submit" 
                                                            class="btn btn-sm btn-outline-danger action-btn"
                                                            title="Soft Delete">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            <% } else { %>
                                                <!-- Permanent Delete -->
                                                <form action="/admin/students/<%= student.id %>/permanent-delete" 
                                                      method="POST" 
                                                      style="display:inline;"
                                                      onsubmit="return confirm('⚠ WARNING: This will PERMANENTLY delete <%= student.full_name %> and all their data. This cannot be undone! Are you sure?');">
                                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                    <button type="submit" 
                                                            class="btn btn-sm btn-outline-danger action-btn"
                                                            title="Permanent Delete">
                                                        <i class="bi bi-exclamation-triangle"></i>
                                                    </button>
                                                </form>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </main>
    </div>
</div>

<!-- Add Student Modal -->
<div class="modal fade" id="addStudentModal" tabindex="-1" aria-labelledby="addStudentModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content rounded-1 border-0 shadow">
            <div class="modal-header bg-dark text-white rounded-0">
                <h5 class="modal-title text-uppercase fw-bold small" id="addStudentModalLabel">
                    <i class="bi bi-person-plus"></i> Register New Student
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/admin/students/create" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label text-uppercase small fw-bold text-muted">
                            Full Name <span class="text-danger">*</span>
                        </label>
                        <input type="text" name="fullName" class="form-control rounded-1" 
                               placeholder="Enter student's full name" required>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label text-uppercase small fw-bold text-muted">
                            Class <span class="text-danger">*</span>
                        </label>
                        <select name="className" class="form-select rounded-1" required>
                            <option value="">-- Select Class --</option>
                            <% if (typeof classes !== 'undefined' && classes.length > 0) { %>
                                <% classes.forEach(function(cls) { %>
                                    <option value="<%= cls.id %>"><%= cls.class_name %></option>
                                <% }) %>
                            <% } else { %>
                                <option value="" disabled>No classes available</option>
                            <% } %>
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label text-uppercase small fw-bold text-muted">
                            Parent Phone Number
                        </label>
                        <input type="text" name="parentPhone" class="form-control rounded-1" 
                               placeholder="Enter parent's phone number (optional)">
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label text-uppercase small fw-bold text-muted">
                            Password <span class="text-danger">*</span>
                        </label>
                        <input type="text" name="customPassword" class="form-control rounded-1" 
                               placeholder="Set student password" required minlength="4">
                        <small class="text-muted">Minimum 4 characters. Student will use this with their generated ID to login.</small>
                    </div>
                </div>
                <div class="modal-footer bg-light rounded-0">
                    <button type="button" class="btn btn-secondary btn-sm rounded-1" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-dark btn-sm rounded-1 text-uppercase fw-bold">
                        <i class="bi bi-check-lg"></i> Register Student
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>