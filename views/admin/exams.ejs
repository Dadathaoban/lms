<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CBT Examination Engine</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #fcfcfc; color: #111111; font-family: 'Segoe UI', system-ui, sans-serif; }
        .sidebar { background-color: #ffffff; min-height: 100vh; border-right: 1px solid #eaeaea; }
        .sidebar .nav-link { color: #444444; font-weight: 500; border-radius: 2px; margin-bottom: 4px; padding: 10px 15px; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.05em; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { background-color: #000000; color: #ffffff; }
        .card-custom { border: 1px solid #eaeaea; border-radius: 2px; background-color: #ffffff; }
        .table-custom { border: 1px solid #eaeaea; background-color: #ffffff; }
        .table-custom th { background-color: #000000; color: #ffffff; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05em; }
        .border-black-thick { border-top: 3px solid #000000; }
    </style>
</head>
<body>

<div class="container-fluid">
    <div class="row">
        <nav class="col-md-3 col-lg-2 d-md-block sidebar p-3">
            <div class="position-sticky">
                <div class="px-2 py-3 mb-3 border-bottom">
                    <h6 class="fw-bold text-uppercase m-0 tracking-wide">HLT TERMINAL</h6>
                    <small class="text-muted font-monospace" style="font-size: 0.7rem;">SYS-ADMIN v1.0</small>
                </div>
                <ul class="nav flex-column">
                    <li class="nav-item"><a class="nav-link" href="/admin/dashboard">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/students">Students</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/curriculum">Subjects & Lessons</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/admin/exams">Exams Module</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/result">Results Portal</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/diagnostic/exam-health">Diagnostics</a></li>
                    <li class="nav-item mt-4"><a class="nav-link text-danger border border-danger-subtle text-center" href="/logout">Secure Signout</a></li>
                </ul>
            </div>
        </nav>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 border-bottom">
                <h2 class="fw-bold text-uppercase tracking-tight">CBT Examination Blueprint Engine</h2>
                <div class="text-muted font-monospace small">Operator: <%= user.fullName %></div>
            </div>

            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="card card-custom p-4 shadow-sm border-black-thick">
                        <h5 class="fw-bold text-uppercase mb-3">Deploy Assessment Profile</h5>
                        <form action="/admin/exams/create" method="POST">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <div class="mb-3">
                                <label class="form-label text-uppercase small fw-bold text-muted">Assessment Title</label>
                                <input type="text" name="title" class="form-control rounded-1" placeholder="e.g., First Semester Examination" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-uppercase small fw-bold text-muted">Subject Track</label>
                                <select name="subjectId" class="form-select rounded-1" required>
                                    <option value="" disabled selected>Choose Subject...</option>
                                    <% subjects.forEach(function(s) { %>
                                        <option value="<%= s.id %>"><%= s.subject_name %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-uppercase small fw-bold text-muted">Class Target</label>
                                <select name="classId" class="form-select rounded-1" required>
                                    <option value="" disabled selected>Choose Level...</option>
                                    <% classes.forEach(function(c) { %>
                                        <option value="<%= c.id %>"><%= c.class_name %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="mb-4">
                                <label class="form-label text-uppercase small fw-bold text-muted">Time Allowance (Minutes)</label>
                                <input type="number" name="durationMinutes" class="form-control rounded-1 font-monospace" placeholder="e.g., 60" min="1" required>
                            </div>
                            <button type="submit" class="btn btn-dark w-100 py-2 text-uppercase fw-bold tracking-wide rounded-1">Commit Exam Framework</button>
                        </form>
                    </div>
                </div>

                <div class="col-lg-8">
                    <div class="card card-custom p-4 shadow-sm">
                        <h5 class="fw-bold text-uppercase mb-3">Active Assessment Control Registry</h5>
                        <div class="table-responsive">
                            <table class="table table-custom align-middle text-center mb-0">
                                <thead>
                                    <tr>
                                        <th class="py-3">Level</th>
                                        <th class="py-3">Subject Track</th>
                                        <th class="py-3">Assessment Title</th>
                                        <th class="py-3">Timer Allocation</th>
                                        <th class="py-3">Questions Count</th>
                                        <th class="py-3">Attempts Limit</th>
                                        <th class="py-3">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (exams.length === 0) { %>
                                        <tr>
                                            <td colspan="7" class="text-muted font-monospace py-4 small">No active assessment profiles compiled in system storage nodes. Use deployment controls to compile layouts.</td>
                                        </tr>
                                    <% } else { %>
                                        <% exams.forEach(function(exam) { %>
                                            <tr>
                                                <td class="font-monospace fw-bold py-3"><%= exam.class_name %></td>
                                                <td><span class="badge bg-dark px-2 py-1"><%= exam.subject_name %></span></td>
                                                <td class="text-start ps-2 fw-semibold"><%= exam.title %></td>
                                                <td class="font-monospace"><%= exam.duration_minutes %> MIN</td>
                                                <td class="font-monospace text-muted fw-bold"><%= exam.question_count %> Items</td>
                                                <td>
                                                    <form action="/admin/exams/<%= exam.id %>/alter-attempts" method="POST" class="d-flex align-items-center gap-1">
                                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="number" 
           name="allowedAttempts" 
           value="<%= exam.allowed_attempts !== undefined && exam.allowed_attempts !== null ? exam.allowed_attempts : 1 %>" 
           min="1" 
           class="form-control form-control-sm font-monospace text-center" 
           style="width: 65px;">
    
    <button type="submit" class="btn btn-sm btn-dark rounded-1 font-monospace" style="font-size: 0.75rem; padding: 4px 8px;">
        Update
    </button>
</form>
                                                </td>
                                                <td>
                                                    <a href="/admin/exams/<%= exam.id %>/questions" class="btn btn-sm btn-outline-dark font-monospace rounded-1 px-2 py-1">
                                                        ⚙ Manage Questions
                                                    </a>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>