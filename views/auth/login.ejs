<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portal Authentication</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #fafafa; color: #111111; font-family: 'Segoe UI', system-ui, sans-serif; min-height: 100vh; display: flex; flex-direction: column; }
        .btn-premium-dark { background-color: #000000; color: #ffffff; border: 1px solid #000000; transition: all 0.2s ease; }
        .btn-premium-dark:hover { background-color: #ffffff; color: #000000; }
        .card-custom { border: 1px solid #e5e5e5; border-radius: 4px; background-color: #ffffff; }
    </style>
</head>
<body>

    <div class="container d-flex justify-content-center align-items-center my-auto" style="min-height: 80vh;">
        <div class="card card-custom p-4 shadow-sm" style="width: 100%; max-width: 400px;">
            <div class="text-center mb-4">
                <h4 class="fw-bold text-uppercase tracking-wider m-0">Secure Gateway</h4>
                <small class="text-muted text-uppercase font-monospace" style="font-size: 0.75rem;">Authorization Required</small>
            </div>
            
            <% if (error) { %>
                <div class="alert alert-dark text-center py-2 font-monospace mb-3 rounded-1" style="font-size: 0.8rem; background-color: #111; color: #fff;"><%= error %></div>
            <% } %>

            <form action="/login" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="mb-3">
                    <label for="username" class="form-label text-uppercase small fw-bold text-muted">User ID</label>
                    <input type="text" class="form-control rounded-1 py-2 font-monospace" id="username" name="username" placeholder="e.g., HLT26001" required>
                </div>
                <div class="mb-4">
                    <label for="password" class="form-label text-uppercase small fw-bold text-muted">Password</label>
                    <input type="password" class="form-control rounded-1 py-2" id="password" name="password" placeholder="••••••••" required>
                </div>
                <button type="submit" class="btn btn-premium-dark w-100 py-2 text-uppercase fw-bold tracking-wide rounded-1">Authenticate</button>
            </form>
        </div>
    </div>

    <footer class="text-center py-4 border-top border-light mt-auto bg-white">
        <p class="text-muted small mb-0">&copy; 2026 Home Lesson Tutorials.</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
