<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Performance Records</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #fcfcfc; color: #111111; font-family: 'Segoe UI', system-ui, sans-serif; }
        .sidebar { background-color: #ffffff; min-height: 100vh; border-right: 1px solid #eaeaea; }
        .sidebar .nav-link { color: #444444; font-weight: 500; padding: 10px 15px; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.05em; border-radius: 2px; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { background-color: #000000; color: #ffffff; }
        .table-custom { background-color: #ffffff; border: 1px solid #eaeaea; }
    </style>
</head>
<body>

<div class="container-fluid">
    <div class="row">
        <nav class="col-md-3 col-lg-2 d-md-block sidebar p-3">
            <div class="position-sticky">
                <div class="px-2 py-3 mb-3 border-bottom">
                    <h6 class="fw-bold text-uppercase m-0">STUDENT PORTAL</h6>
                </div>
                <ul class="nav flex-column">
                    <li class="nav-item"><a class="nav-link" href="/student/dashboard">My Courseware</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/student/results">Performance Records</a></li>
                    <li class="nav-item mt-4"><a class="nav-link text-danger border border-danger-subtle text-center" href="/logout">Secure Signout</a></li>
                </ul>
            </div>
        </nav>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
            <div class="pt-3 pb-2 mb-4 border-bottom">
                <h2 class="fw-bold text-uppercase tracking-tight">Personal Academic Records</h2>
                <p class="text-muted">Review your verified computer-based test performance history.</p>
            </div>

            <div class="card table-custom shadow-sm p-4">
                <% if (results.length === 0) { %>
                    <div class="text-center py-5">
                        <p class="text-muted font-monospace mb-0">You haven't submitted any examination entries yet.</p>
                    </div>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle m-0">
                            <thead class="table-dark font-monospace text-uppercase" style="font-size: 0.75rem;">
                                <tr>
                                    <th>Subject</th>
                                    <th>Exam Assessment Profile</th>
                                    <th class="text-center">Raw Score</th>
                                    <th class="text-center">Percentage</th>
                                    <th>Date Evaluated</th>
                                </tr>
                            </thead>
                            <tbody class="font-monospace" style="font-size: 0.85rem;">
                                <% results.forEach(function(row) { %>
                                    <tr>
                                        <td class="fw-bold"><%= row.subject_name %></td>
                                        <td><%= row.exam_title %></td>
                                        <td class="text-center text-primary fw-bold"><%= row.score_obtained %> / <%= row.total_questions %></td>
                                        <td class="text-center">
                                            <span class="badge <%= row.percentage >= 50 ? 'bg-success' : 'bg-danger' %> rounded-1">
                                                <%= parseFloat(row.percentage).toFixed(2) %>%
                                            </span>
                                        </td>
                                        <td class="text-muted"><%= row.submission_date %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </main>
    </div>
</div>

</body>
</html>